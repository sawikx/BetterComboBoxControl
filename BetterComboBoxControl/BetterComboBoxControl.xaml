<UserControl x:Class="BetterComboBoxControl.BetterComboBoxControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BetterComboBoxControl"
             mc:Ignorable="d" 
             d:DesignHeight="35">
    <Grid Width="250">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ComboBox x:Name="SelectionComboBox" Grid.Column="0" 
              VerticalContentAlignment="Center"
              SelectionChanged="SelectionComboBox_SelectionChanged" FontSize="14">            
        </ComboBox>

        <Grid x:Name="CustomInputGrid" Grid.Column="1" Margin="10,0,0,0" Visibility="Visible">
            <TextBox x:Name="txtInput" 
                 VerticalAlignment="Center" FontSize="14" FontWeight="Light" 
                 Background="Transparent" Padding="5,0,30,0"
                 TextChanged="txtInput_TextChanged"/>

            <TextBlock x:Name="tbBackgroundText" 
                   IsHitTestVisible="False"
                   Text="Other option..." FontSize="14" FontWeight="Light" 
                   Foreground="DarkGray" VerticalAlignment="Center" 
                   Margin="10,0,0,0" Panel.ZIndex="-1" Cursor=""/>

            <Button x:Name="btnClear" Width="20" Height="20" 
                HorizontalAlignment="Right" Content="✕" 
                Background="Transparent" Foreground="LightGray" 
                BorderThickness="0" Click="btnClear_Click"
                Cursor="Hand"/>
        </Grid>
    </Grid>
</UserControl>

